flowchart TD
  %%* 🩺 Solo Doctor — 👤 Solo Secretario y Administrador — 🔒 Solo Administrador

  AUTH["🔐 Autenticación"]
  AUTH --> LOGIN["Iniciar sesión"]
  AUTH --> RECOVER["Recuperar contraseña"]

  DASH["🏠 Dashboard"]

  PERFIL["👤 Perfil / Cerrar sesión"]

  subgraph MED["💊 Módulo Médico"]
    PAC["Pacientes"]
    PAC --> PAC_LIST["Listado"]
    PAC --> PAC_NEW["Registrar"]
    PAC --> PAC_DETAIL["Detalle"]
    PAC_DETAIL --> PAC_EDIT["Editar"]
    PAC_DETAIL --> HIST["Historial médico"]
    HIST --> ANT_LIST["Antecedentes"]
    ANT_LIST --> ANT_NEW["Registrar antecedente"]
    ANT_LIST --> ANT_EDIT["Editar antecedente"]
    PAC_DETAIL --> PAC_CITAS["Historial de citas"]

    CITAS["Citas"]
    CITAS --> CIT_LIST["Listado"]
    CITAS --> CIT_NEW["Agendar"]
    CITAS --> CIT_DETAIL["Detalle"]
    CIT_DETAIL --> CIT_RESULT["Registrar resultado 🩺"]
    CIT_DETAIL --> RECIPE_PDF["Generar récipe PDF"]
    
    REC_EXT["Récipes externos"]
    REC_EXT --> REC_EXT_LIST["Listado"]
    REC_EXT --> REC_EXT_NEW["Registrar"]
    REC_EXT --> REC_EXT_DETAIL["Detalle"]
  end

  subgraph INV["📦 Módulo Inventario"]
    INSUMOS["Inventario"]
    INSUMOS --> INS_LIST["Listado"]
    INSUMOS --> INS_DETAIL["Detalle"]
    INS_DETAIL --> INS_EDIT["Editar"]
    INS_DETAIL --> INS_DISP["Registrar dispensación"]

    CATALOGOS["Catálogos"]
    CATALOGOS --> CAT_MED["Medicamentos"]
    CATALOGOS --> CAT_MAT["Materiales quirúrgicos"]
    CATALOGOS --> CAT_CAT["Categorías"]
    CATALOGOS --> CAT_PA["Principios activos"]
    CATALOGOS --> CAT_LAB["Laboratorios y marcas"]
    CATALOGOS --> CAT_MISC["Formas / Vías / Empaques"]
  end

  subgraph DON["🎁 Módulo Donaciones"]
    DONACIONES["Donaciones"]
    DONACIONES --> DON_LIST["Listado"]
    DONACIONES --> DON_NEW["Registrar donación"]
    DONACIONES --> DON_DETAIL["Detalle"]

    DONANTES["Donantes"]
    DONANTES --> DON_LIST2["Listado"]
    DONANTES --> DON_NEW2["Registrar / Editar"]
    DONANTES --> DON_DETAIL2["Detalle"]
  end

  subgraph CONT["📒 Módulo Contable"]
    LIBRO["Libro diario 👤"]
    LIBRO --> LIBRO_LIST["Listado de asientos"]
    LIBRO --> LIBRO_DETAIL["Detalle de asiento"]
    ESTADO["Estado de resultados 👤"]
    EGRESO["Registrar egreso puntual"]
  end

  subgraph AUD["🔍 Auditoría 🔒"]
    AUD_PAC["Auditoría pacientes"]
    AUD_ANT["Auditoría antecedentes"]
    AUD_CIT["Auditoría citas"]
    AUD_INS["Auditoría insumos"]
    AUD_DON["Auditoría donantes/donaciones"]
    AUD_ASI["Auditoría asientos"]
    AUD_REC["Auditoría récipes externos"]
    AUD_CONS["Accesos a consultas contables"]
  end

  subgraph ADMIN["⚙️ Administración 🔒"]
    PERSONAL["Personal"]
    PERSONAL --> PER_LIST["Listado"]
    PERSONAL --> PER_NEW["Registrar"]
    PERSONAL --> PER_EDIT["Editar / Desactivar"]
    SYSCONFIG["Configuración del sistema"]
  end

  LOGIN --> DASH
  DASH --> MED
  DASH --> INV
  DASH --> DON
  DASH --> CONT
  DASH --> AUD
  DASH --> ADMIN
  DASH --> PERFIL